# Discord

DISCORD_TOKEN=your_discord_bot_token

DISCORD_CLIENT_ID=your_discord_application_client_id

DISCORD_GUILD_ID=your_test_server_id_for_fast_command_sync



# ─── Supabase (recommended — auto-builds Postgres URLs) ────────────────────

# From Supabase → Project Settings → API

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

SUPABASE_ANON_KEY=your_publishable_or_anon_key



# From Supabase → Project Settings → Database → database password

SUPABASE_DB_PASSWORD=your_database_password



# Optional: Transaction pooler region (Project Settings → General → Region)

# SUPABASE_REGION=eu-central-2

# Optional override: SUPABASE_POOLER_HOST=aws-1-eu-central-2.pooler.supabase.com



# Legacy Next.js names also work:

# NEXT_PUBLIC_SUPABASE_URL=...

# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=...



# Or paste full connection strings manually (overrides auto-build):

# DATABASE_URL="postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10"

# DIRECT_DATABASE_URL="postgresql://postgres:PASSWORD@db.YOUR_REF.supabase.co:5432/postgres"



# AI Provider: openai | mock

AI_PROVIDER=mock

AI_API_KEY=your_openai_api_key

AI_MODEL_CONTROLLER=gpt-4o-mini

AI_MODEL_NARRATOR=gpt-4o-mini

AI_MODEL_MEMORY=gpt-4o-mini

AI_TIMEOUT_MS=30000



# Image Provider: stub | openai

IMAGE_PROVIDER=stub

IMAGE_API_KEY=your_image_api_key

IMAGE_MODEL=dall-e-3

IMAGE_AUTO_GENERATE=false

IMAGE_DAILY_LIMIT_PER_CAMPAIGN=10

IMAGE_USER_COOLDOWN_MS=60000



# Bot operator Discord IDs (comma-separated)

ADMIN_DISCORD_IDS=your_discord_user_id



LOG_LEVEL=info

NODE_ENV=development

